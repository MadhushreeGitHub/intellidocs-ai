# ============================================================
# .env.example
# Copy this to .env and fill in real values
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Database
DATASOURCE_URL=jdbc:postgresql://localhost:5432/intellidocs
DATASOURCE_USERNAME=intellidocs
DATASOURCE_PASSWORD=your_strong_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=intellidocs
RABBITMQ_PASS=your_rabbitmq_password_here

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=generate_a_random_64_char_string_here_never_use_this_default_value

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# File storage
STORAGE_PATH=/tmp/intellidocs/uploads

# Docker Compose (used by docker-compose.yml directly)
POSTGRES_DB=intellidocs
POSTGRES_USER=intellidocs
POSTGRES_PASSWORD=your_strong_db_password_here
